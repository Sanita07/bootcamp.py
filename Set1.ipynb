   "source": [
    "i=input(\"Enter items\")\n",
    "my_list=i.split()\n",
    "print(my_list)\n",
    "max=int(my_list[0])\n",
    "min=int(my_list[0])\n",
    "sum=0\n",
    "for i in my_list:\n",
    "    val=int(i)\n",
    "    sum+=val\n",
    "    if val>max:\n",
    "        max=val\n",
    "    if val<min:\n",
    "        min=val\n",
    "        \n",
    "print(max)\n",
    "print(min)\n",
    "print(sum)"
   ]
